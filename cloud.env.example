# Temporal Cloud connection settings
# Copy this file to cloud.env and fill in your values.
#
# Usage: ./scripts/start.sh --cloud-env cloud.env
#        ./scripts/start.sh --cloud-env cloud.env --encrypt

# Required: Your Temporal Cloud address and namespace
TEMPORAL_ADDRESS=your-namespace.a]2dd6.tmprl.cloud:7233
TEMPORAL_NAMESPACE=your-namespace.a]2dd6

# Authentication — use EITHER API key OR mTLS certificates

# Option 1: API Key (preferred)
TEMPORAL_API_KEY=your-api-key-here

# Option 2: mTLS certificates
# TEMPORAL_CERT_PATH=/path/to/client.pem
# TEMPORAL_KEY_PATH=/path/to/client.key

# Optional: override the task queue name (default: MoneyTransfer)
# TEMPORAL_TASK_QUEUE=MoneyTransfer
